# Copy to /srv/indexcards/.env and fill in values before starting the service.

# Required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# SQLite default works fine. Use a full path so the service finds it reliably.
DATABASE_URL=sqlite:////srv/indexcards/instance/indexcards.db

# Public URL of the site (no trailing slash). Used in emails and feed links.
SITE_URL=https://example.com

# Optional: set to 1 during first-run troubleshooting, then remove.
# FLASK_DEBUG=0
