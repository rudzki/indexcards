# Copy to .env and fill in values before starting the app.

# Required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# SQLite default works fine for local dev. Use a full path in production.
DATABASE_URL=sqlite:///instance/indexcards.db

# Public URL of the site (no trailing slash). Used in emails and feed links.
SITE_URL=http://localhost:5000

# Set to 1 for local dev, 0 in production.
FLASK_DEBUG=1